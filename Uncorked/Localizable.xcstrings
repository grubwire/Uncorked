tate" : "translated",\n            "value" : "Move to Applications"\n          }\n        },\n        "es" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Mover a Aplicaciones"\n          }\n        },\n        "fi" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Siirrä Applikaatioihin"\n          }\n        },\n        "fr" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Déplacer vers Applications"\n          }\n        },\n        "it" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Sposta in Applicazioni"\n          }\n        },\n        "ja" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "「アプリケーション」に移動"\n          }\n        },\n        "ko" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "애플리케이션 폴더로 옮기기"\n          }\n        },\n        "nl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Ga naar Toepassingen"\n          }\n        },\n        "pl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Przenieś do folderu Aplikacje"\n          }\n        },\n        "pt-BR" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Mover para Aplicativos"\n          }\n        },\n        "pt-PT" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Mover para Aplicações"\n          }\n        },\n        "ro" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Mutare în Aplicații"\n          }\n        },\n        "ru" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Перенести в «Приложения»"\n          }\n        },\n        "tr" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Uygulamalar'a Taşı"\n          }\n        },\n        "uk" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Перемістити до Застосунків"\n          }\n        },\n        "vi" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Chuyển tới Applications"\n          }\n        },\n        "zh-Hans" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "移动到应用程序文件夹"\n          }\n        },\n        "zh-Hant" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "移動到應用程式"\n          }\n        }\n      }\n    },\n    "showAlertOnFirstLaunch.informativeText" : {\n      "localizations" : {\n        "ar" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "في بعض الحالات، Uncorked لن يكون قادراً على العمل بشكل صحيح من مجلد مختلف"\n          }\n        },\n        "cs" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "V některých případech nemusí být Uncorked schopna správně fungovat z jiné složky"\n          }\n        },\n        "da" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "I nogle tilfælde vil Uncorked ikke være i stand til at fungere korrekt fra en anden mappe"\n          }\n        },\n        "de" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "In manchen Fällen wird Uncorked nicht richtig funktionieren, wenn es in einem anderen Ordner gespeichert ist"\n          }\n        },\n        "en" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "In some cases, Uncorked won't be able to function properly from a different folder"\n          }\n        },\n        "es" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "En algunos casos, Uncorked podría no funcionar correctamente desde una carpeta diferente"\n          }\n        },\n        "fi" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Joissakin tapauksissa, Uncorkedn ei ole mahdollista toimia kunnolla muista kansioista"\n          }\n        },\n        "fr" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Dans certains cas, Uncorked ne pourra pas fonctionner correctement depuis un dossier différent"\n          }\n        },\n        "it" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "In alcuni casi, Uncorked non potrà funzionare correttamente da un cartella diversa"\n          }\n        },\n        "ja" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "場合によっては、異なるフォルダから Uncorked を適切に使用できない場合があります"\n          }\n        },\n        "ko" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "경우에 따라 다른 폴더에서는 Uncorked가 제대로 동작하지 않을 수 있습니다."\n          }\n        },\n        "nl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "In sommige gevallen zal Whiskey niet goed kunnen functioneren vanuit een andere map"\n          }\n        },\n        "pl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "W niektórych przypadkach Uncorked nie będzie w stanie działać poprawnie w innym folderze"\n          }\n        },\n        "pt-BR" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Em alguns casos, o Uncorked pode não funcionar corretamente numa pasta diferente"\n          }\n        },\n        "pt-PT" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Em alguns casos, o Uncorked pode não funcionar corretamente numa pasta diferente"\n          }\n        },\n        "ro" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "În unele cazuri, Uncorked nu va putea funcționa corect dintr-un folder diferit"\n          }\n        },\n        "ru" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "В некоторых случаях Uncorked не сможет правильно функционировать из другой папки"\n          }\n        },\n        "tr" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Bazı durumlarda, Uncorked başka bir klasörden düzgün çalışamayabilir"\n          }\n        },\n        "uk" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "У деяких випадках, Uncorked може не працювати належним чином з іншої папки"\n          }\n        },\n        "vi" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Trong một số trường hợp, Uncorked sẽ không hoạt động đúng nếu không nằm trong Applications"\n          }\n        },\n        "zh-Hans" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "在某些情况下，Uncorked 可能无法在其他的文件夹中正常工作"\n          }\n        },\n        "zh-Hant" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "在某些情況下，Uncorked 可能無法在不同的資料夾中正常運作"\n          }\n        }\n      }\n    },\n    "showAlertOnFirstLaunch.messageText" : {\n      "localizations" : {\n        "ar" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "هل ترغب في نقل Uncorked إلى مجلد التطبيقات الخاص بك؟"\n          }\n        },\n        "cs" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Chtěli byste přesunout Uncorked do složky s aplikacemi?"\n          }\n        },\n        "da" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Vil du flytte Uncorked til Applications mappen?"\n          }\n        },\n        "de" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Möchtest du Uncorked in deinen Programm-Ordner legen?"\n          }\n        },\n        "en" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Would you like to move Uncorked to your Applications folder?"\n          }\n        },\n        "es" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "¿Te gustaría mover Uncorked a la carpeta de Aplicaciones?"\n          }\n        },\n        "fi" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Haluatko siirtää Uncorkedn Applikaatio-kansioon?"\n          }\n        },\n        "fr" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Souhaitez-vous déplacer Uncorked dans votre dossier Applications ?"\n          }\n        },\n        "it" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Vuoi spostare Uncorked nella tua cartella Applicazioni?"\n          }\n        },\n        "ja" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Uncorked を「アプリケーション」フォルダに移動しますか？"\n          }\n        },\n        "ko" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Uncorked를 애플리케이션 폴더로 옮기시겠습니까?"\n          }\n        },\n        "nl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Wilt u Whiskey verplaatsen naar uw map Toepassingen?"\n          }\n        },\n        "pl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Czy chcesz przenieść Uncorked do folderu Aplikacje?"\n          }\n        },\n        "pt-BR" : {\n          "stringUnit" : {\n            "state" : "tran