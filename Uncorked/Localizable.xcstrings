,\n            "value" : "インストール済みのプログラム"\n          }\n        },\n        "ko" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "설치된 프로그램"\n          }\n        },\n        "nl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Geïnstalleerde programma's"\n          }\n        },\n        "pl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Zainstalowane programy"\n          }\n        },\n        "pt-BR" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Programas Instalados"\n          }\n        },\n        "pt-PT" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Programas Instalados"\n          }\n        },\n        "ro" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Programe Instalate"\n          }\n        },\n        "ru" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Установленные программы"\n          }\n        },\n        "tr" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "İndirilmiş Programlar"\n          }\n        },\n        "uk" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Встановлені програми"\n          }\n        },\n        "vi" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Ứng dụng đã cài đặt"\n          }\n        },\n        "zh-Hans" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "已安装的程序"\n          }\n        },\n        "zh-Hant" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "已安裝的程式"\n          }\n        }\n      }\n    },\n    "update.engine.description" : {\n      "localizations" : {\n        "ar" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "أنت تقوم بتشغيل Uncorked %@، ولكن %@ متوفر. هل ترغب في التحديث؟"\n          }\n        },\n        "cs" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Máte spuštěnou %@, ale %@ není k dispozici. Chcete aktualizovat?"\n          }\n        },\n        "da" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Du kører Uncorked %@, men %@ er tilgængelig. Ønsker du at opdatere?"\n          }\n        },\n        "de" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Sie verwenden Uncorked %@, die aktuelle Version ist %@. Möchten Sie Uncorked aktualisieren?"\n          }\n        },\n        "en" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "You are running Uncorked %@, but %@ is available. Would you like to update?"\n          }\n        },\n        "es" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Estás ejecutando Uncorked %@, pero %@ está disponible. ¿Quieres actualizar?"\n          }\n        },\n        "fi" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Käytössäsi on Uncorked %@, mutta %@ on saatavilla. Haluatko päivittää sen?"\n          }\n        },\n        "fr" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Vous utilisez Uncorked %@, mais %@ est disponible. Voulez-vous le mettre à jour ?"\n          }\n        },\n        "it" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Stai utilizzando Uncorked %@, ma %@ è disponibile. Vuoi aggiornare?"\n          }\n        },\n        "ja" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "現在 Uncorked %@ を使用していますが、 %@ を利用可能です。アップデートしますか？"\n          }\n        },\n        "ko" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Uncorked %@ 버전을 사용 중이지만 %@ 버전을 사용할 수 있습니다. 업데이트하시겠습니까?"\n          }\n        },\n        "nl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "U gebruikt Uncorked %@, maar %@ is beschikbaar. Wilt u updaten?"\n          }\n        },\n        "pl" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Używasz Uncorked %@, lecz nowsza wersja %@ jest dostępna. Czy chcesz zaktualizować?"\n          }\n        },\n        "pt-BR" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Uncorked %@ está sendo usada, mas %@ está disponível. Atualizar?"\n          }\n        },\n        "pt-PT" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Está a usar o Uncorked %@, mas o %@ está disponível. Gostaria de atualizar?"\n          }\n        },\n        "ro" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Dvs. rulați Uncorked %@, dar %@ este disponibil. Doriți să actualizați?"\n          }\n        },\n        "ru" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Вы используете Uncorked %@, но %@ доступен. Желаете обновить?"\n          }\n        },\n        "tr" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Uncorked %@ versiyonu kullanıyorsunuz ama %@ versiyonu mevcut. Güncellemek ister misiniz?"\n          }\n        },\n        "uk" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Ви використовуєте Uncorked %@, але доступна версія %@. Оновити?"\n          }\n        },\n        "vi" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Bạn đang sử dụng Uncorked phiên bản %@, nhưng phiên bản%@ đã được phát hành. Bạn có muốn cập nhật không?"\n          }\n        },\n        "zh-Hans" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "您正在运行 Uncorked %@，但 %@ 可用。您想要更新吗？"\n          }\n        },\n        "zh-Hant" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "您正在使用Uncorked %@, %@已可更新 請問是否要更新?"\n          }\n        }\n      }\n    },\n    "update.engine.title" : {\n      "localizations" : {\n        "ar" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "إصدار جديد من Uncorked متوفر"\n          }\n        },\n        "cs" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "K dispozici je nová verze Uncorked"\n          }\n        },\n        "da" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Ny version af Uncorked tilgængelig"\n          }\n        },\n        "de" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Eine neue Uncorked Version ist verfügbar"\n          }\n        },\n        "en" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "New Version of Uncorked Available"\n          }\n        },\n        "es" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Nueva versión de Uncorked disponible"\n          }\n        },\n        "fi" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Uusi Uncorked versio on saatavilla"\n          }\n        },\n        "fr" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Nouvelle version de Uncorked disponible"\n          }\n        },\n        "it" : {\n          "stringUnit" : {\n            "state" : "translated",\n            "value" : "Nuova versione di Uncorked 